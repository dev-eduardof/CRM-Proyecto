# Usar cuando el frontend ya fue construido en el host (npm run build).
# Uso con contexto = frontend/ (para que dist/ no quede excluido por .dockerignore raíz):
#   docker build -f frontend/Dockerfile.prod.nginx-only -t crm-proyecto_frontend frontend/
FROM nginx:alpine
COPY dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
